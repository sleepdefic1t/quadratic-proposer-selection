+// scaledSqrt computes sqrt(vp << 32) for quadratic proposer selection test expectations.
+// Mirrors the fixed-point integer sqrt used in validator_set.go.
+func scaledSqrt(vp int64) int64 {
+	s := new(big.Int).Lsh(big.NewInt(vp), 32)
+	return s.Sqrt(s).Int64()
+}
+
+// normalizedWeight computes the expected priority increment for a validator
+// under quadratic proposer selection with normalization back to totalVP scale.
+func normalizedWeight(vp, totalVP int64, allVPs []int64) int64 {
+	sumOfScaled := int64(0)
+	for _, v := range allVPs {
+		sumOfScaled += scaledSqrt(v)
+	}
+	n := big.NewInt(scaledSqrt(vp))
+	n.Mul(n, big.NewInt(totalVP))
+	n.Div(n, big.NewInt(sumOfScaled))
+	return n.Int64()
+}
+
+// sumNormalized computes sumOfNormalized (may differ from totalVP due to integer truncation).
+func sumNormalized(totalVP int64, allVPs []int64) int64 {
+	sum := int64(0)
+	for _, vp := range allVPs {
+		sum += normalizedWeight(vp, totalVP, allVPs)
+	}
+	return sum
+}
+
