+// Quadratic Proposer Selection
+//
+// Replaces CometBFT's linear proposer selection.
+// Quadratic Proposer weight is proportional to sqrt(stake) rather than stake,
+// normalized to totalVotingPower scale:
+//
+//   weight_i = (sqrt(s_i) / sum(sqrt(s_j))) * totalVP
+//
+// sqrt is computed as isqrt(stake << 32) for 16-bit fixed-point precision.
+// BFT commit voting remains linear -- only block production frequency changes.
+//
+// Equilibrium: subadditive weighting taxes concentration, operational costs
+// tax fragmentation.
+
 package types
 
 import (
@@ -30,6 +44,11 @@ const (
 	// total voting power gives the maximum allowed distance between validator
 	// priorities.
 	PriorityWindowSizeFactor = 2
+
+	// quadraticResolution is the number of bits to left-shift voting power
+	// before computing isqrt for quadratic proposer selection.
+	// This provides higher granularity (2^16) in sqrt output.
+	quadraticResolution = 32
 )
 
 // ErrTotalVotingPowerOverflow is returned if the total voting power of the
@@ -179,19 +198,47 @@ func (vals *ValidatorSet) RescalePriorities(diffMax int64) {
 }
 
 func (vals *ValidatorSet) incrementProposerPriority() *Validator {
+	sumOfScaled := big.NewInt(vals.getSumOfScaledQuadraticWeights())
+	totalVotingPower := big.NewInt(vals.TotalVotingPower())
+	sumOfNormalized := int64(0)
+
 	for _, val := range vals.Validators {
-		// Check for overflow for sum.
-		newPrio := safeAddClip(val.ProposerPriority, val.VotingPower)
-		val.ProposerPriority = newPrio
+		normalized := big.NewInt(0)
+
+		// Only compute normalization if we have voting power.
+		if sumOfScaled.Sign() > 0 {
+			// (scaled * totalVP) / sumOfScaledWeights
+			normalized = big.NewInt(getScaledQuadraticWeight(val.VotingPower))
+			normalized.Mul(normalized, totalVotingPower)
+			normalized.Div(normalized, sumOfScaled)
+		}
+		sumOfNormalized = safeAddClip(sumOfNormalized, normalized.Int64())
+		val.ProposerPriority = safeAddClip(val.ProposerPriority, normalized.Int64())
 	}
-	// Decrement the validator with most ProposerPriority.
+
+	// Decrement sum of normalized weights from highest priority validator.
 	mostest := vals.getValWithMostPriority()
-	// Mind the underflow.
-	mostest.ProposerPriority = safeSubClip(mostest.ProposerPriority, vals.TotalVotingPower())
+	// Mind the underflow
+	mostest.ProposerPriority = safeSubClip(mostest.ProposerPriority, sumOfNormalized)
 
 	return mostest
 }
 
+// getScaledQuadraticWeight returns sqrt(votingPower) with fixed-point precision.
+func getScaledQuadraticWeight(votingPower int64) int64 {
+	scaled := big.NewInt(votingPower)
+	scaled.Lsh(scaled, quadraticResolution) // votingPower << 32
+	return scaled.Sqrt(scaled).Int64()      // sqrt(scaled)
+}
+
+func (vals *ValidatorSet) getSumOfScaledQuadraticWeights() int64 {
+	sumOfScaled := int64(0)
+	for _, val := range vals.Validators {
+		sumOfScaled = safeAddClip(sumOfScaled, getScaledQuadraticWeight(val.VotingPower))
+	}
+	return sumOfScaled
+}
+
